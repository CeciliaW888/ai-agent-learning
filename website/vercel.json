{
  "buildCommand": "",
  "outputDirectory": ".",
  "routes": [
    { "src": "/sw.js", "dest": "/sw.js" },
    { "src": "/manifest.json", "dest": "/manifest.json" },
    { "src": "/offline.html", "dest": "/offline.html" },
    { "src": "/icon-(.*).png", "dest": "/icon-$1.png" },
    { "src": "/apple-touch-icon.png", "dest": "/apple-touch-icon.png" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
