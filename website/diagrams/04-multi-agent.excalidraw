    },
    {
      "id": "flow-steps",
      "type": "text",
      "x": 70,
      "y": 510,
      "width": 760,
      "height": 65,
      "text": "1️⃣ User Request → Coordinator receives topic\n2️⃣ Coordinator → Researcher: \"Find info about X\"\n3️⃣ Researcher → Coordinator: findings → Coordinator → Writer: \"Write about X using these findings\"\n4️⃣ Writer → Coordinator: draft → Coordinator → Editor: \"Polish this draft\"\n5️⃣ Editor → Coordinator: final → Coordinator → User: polished content",
      "fontSize": 13,
      "fontFamily": 1,
      "strokeColor": "#495057"
    },
    {
      "id": "patterns-title",
      "type": "text",
      "x": 50,
      "y": 620,
      "width": 200,
      "height": 25,
      "text": "Common Patterns:",
      "fontSize": 18,
      "fontFamily": 1,
      "strokeColor": "#1e1e1e"
    },
    {
      "id": "patterns",
      "type": "text",
      "x": 50,
      "y": 650,
      "width": 800,
      "height": 60,
      "text": "🏢 Supervisor: One agent delegates (shown above)  |  🤝 Peer: Agents collaborate as equals\n🔗 Pipeline: Sequential handoff (A → B → C)          |  ⚖️ Debate: Agents challenge each other",
      "fontSize": 15,
      "fontFamily": 1,
      "strokeColor": "#495057"
    }
